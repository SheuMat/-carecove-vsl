# Required for live tenders, lead storage, and sync history.
DATABASE_URL=

# Set this to your production domain on Vercel, for example:
# https://care-cove.vercel.app or your custom domain.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional booking URL overrides.
NEXT_PUBLIC_ZOOM_BOOKING_URL=https://scheduler.zoom.us/sheu-matewe/free-consultation
ZOOM_BOOKING_URL=https://scheduler.zoom.us/sheu-matewe/free-consultation

# Required to protect the manual tender refresh API endpoint.
TENDER_REFRESH_SECRET=

# Required to protect the scheduled tender sync endpoint.
CRON_SECRET=

# Optional webhook for qualification lead submissions.
QUALIFY_WEBHOOK_URL=

# Set to true only when running the UI without a database.
USE_DEMO_TENDERS=false
